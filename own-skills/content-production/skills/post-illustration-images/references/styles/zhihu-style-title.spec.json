{
  "id": "zhihu-tech",
  "styleFile": "references/styles/zhihu-style-title.md",
  "platform": "zhihu",
  "canvas": {
    "width": 1600,
    "height": 900,
    "ratio": "16:9",
    "orientation": "horizontal"
  },
  "colors": {
    "background.offWhite": "#F8FAF7",
    "background.blueGray": "#EAF0F4",
    "ink.black": "#171A1F",
    "ink.gray": "#5F6873",
    "card.white": "#FFFFFF",
    "line.gray": "#CBD3DC",
    "accent.orangeRed": "#F0564A",
    "brand.red": "#E63A46"
  },
  "layout": {
    "contentSafeArea": {
      "x": 80,
      "y": 70,
      "width": 1440,
      "height": 760
    },
    "brandReservedArea": {
      "x": 1320,
      "y": 44,
      "width": 240,
      "height": 100
    }
  },
  "fixedComponents": {
    "pageNumberBadge": false,
    "brandSlot": {
      "enabled": true,
      "anchor": "top-right",
      "x": 1350,
      "y": 64,
      "width": 170,
      "height": 46,
      "assetFit": "contain"
    }
  },
  "brandPolicy": {
    "defaultEnabled": true,
    "userOverrideAllowed": true
  },
  "inputHandling": {
    "preserveNativeOutput": true,
    "ratioTolerance": 0.002,
    "outputCanvasRole": "design-coordinate-system",
    "allowPostGenerationResize": false,
    "allowCrop": false,
    "allowPadding": false,
    "allowRotation": false,
    "allowWrongRatioStretch": false,
    "wrongRatioAction": "regenerate"
  },
  "generationConstraints": {
    "forbidModelDrawnBrand": true,
    "forbidPageNumberBadge": true,
    "keepBrandReservedAreaClear": true
  },
  "styleReference": {
    "image": "assets/style-references/zhihu-tech.png",
    "usage": "QA and failure review only; do not use as generation input or copy its content.",
    "contentPolicy": "Ignore all semantic content in the reference image. Compare only baseline visual elements, palette, composition language, texture, typography feel, icon/illustration style, spacing, and non-brand fixed-component treatment. Ignore whether the reference image contains a brand watermark and ignore its brand position; production branding is controlled only by fixedComponents.brandSlot.",
    "isGenerationInput": false
  }
}
